# Copy to .env.local and adjust. Required values have no code defaults.

# --- App (this Next site — metadata, absolute URLs) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database / media (optional) ---
MONGODB_URI=
MONGODB_DB=spacehaat
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Backend API (single origin for every API call) ---
# Use the same pair everywhere: local dev OR production (no trailing slash).
# Local:   http://localhost:8000
# Remote:  https://api.spacehaat.com
API_BASE_URL=https://api.spacehaat.com
NEXT_PUBLIC_API_BASE_URL=https://api.spacehaat.com

# Coworking: set both to "false" to use seed/mock only (server + browser must match).
WORKSPACES_USER_API_PROXY=
NEXT_PUBLIC_WORKSPACES_USER_API_PROXY=

# Timeouts (ms). Browser needs NEXT_PUBLIC_*.
COWORKING_API_TIMEOUT_MS=3500
NEXT_PUBLIC_COWORKING_API_TIMEOUT_MS=3500

# Leads POST defaults to {API_BASE_URL}/api/leads — override only if your path differs.
NEXT_PUBLIC_LEADS_API_URL=
LEADS_API_URL=
LEADS_API_TIMEOUT_MS=8000
NEXT_PUBLIC_LEADS_API_TIMEOUT_MS=8000

# Legacy overrides (optional). If unset, API_BASE_URL / NEXT_PUBLIC_API_BASE_URL are used.
# WORKSPACES_USER_API_BASE_URL=
# NEXT_PUBLIC_WORKSPACES_USER_API_BASE_URL=
